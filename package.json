{
  "name": "user-image-management",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "db:migrate:remote": "wrangler d1 migrations apply user-image-management --remote",
    "deploy": "npm run cf:build && npm run db:migrate:remote && opennextjs-cloudflare deploy",
    "cf:deploy": "npm run db:migrate:remote && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface GeneratedCloudflareEnv cloudflare-env.d.ts",
    "cleanup:dev": "wrangler dev -c wrangler.cleanup.jsonc --test-scheduled",
    "cleanup:deploy": "wrangler deploy -c wrangler.cleanup.jsonc"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "wrangler": "^4.107.1"
  }
}
